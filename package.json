{
  "name": "design-intelligence",
  "version": "0.2.0",
  "description": "An open-source Design Intelligence Layer for AI coding agents — a queryable design brain, not documentation.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/iindrajeet4/design-intelligence",
  "repository": { "type": "git", "url": "https://github.com/iindrajeet4/design-intelligence.git" },
  "bugs": { "url": "https://github.com/iindrajeet4/design-intelligence/issues" },
  "bin": { "design-intelligence": "tools/di.mjs", "di": "tools/di.mjs", "di-mcp": "tools/di-mcp.mjs" },
  "engines": { "node": ">=18" },
  "scripts": {
    "test": "node tools/test.mjs",
    "validate": "node tools/di.mjs validate",
    "build-index": "node tools/di.mjs build-index",
    "check": "node tools/test.mjs && node tools/di.mjs validate && node tools/di.mjs build-index --check",
    "mcp": "node tools/di-mcp.mjs",
    "prepublishOnly": "npm run check"
  },
  "keywords": ["design-system", "ai-agents", "claude-code", "codex", "mcp", "agent-skills", "design-tokens", "accessibility", "ux", "design-review"],
  "files": ["schemas", "skills", "knowledge", "engine", "index", "context", "tools", "CLAUDE.md", "AGENTS.md", "ARCHITECTURE.md"],
  "publishConfig": { "access": "public" },
  "dependencies": {}
}
